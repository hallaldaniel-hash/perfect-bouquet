generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Flower {
  id           String       @id @default(cuid())
  name         String       @unique
  meaning      String
  // Public path to this flower's artwork, e.g. /flowers/white-rose.png.
  // Swap the file to swap the artwork; nothing else needs to change.
  image        String
  // Catalog display order (matches the source contact sheet reading order).
  sortOrder    Int          @unique
  // main | decorative | filler | greenery — groups the selector. Colour variants
  // (White Rose, Pink Rose, ...) are just separate rows sharing a category.
  category     String       @default("main")
  // Kept from the old paid model; unused now that the platform is free, but
  // harmless to retain for a possible future.
  pricePerStem Int          @default(0)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  giftItems    GiftFlower[]
}

model WrapColor {
  id            String     @id @default(cuid())
  name          String     @unique
  color         String
  sortOrder     Int        @unique
  priceModifier Int        @default(0)
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  giftWraps     GiftWrap[]
}

enum GiftStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELED
}

model Gift {
  // Unguessable id — it appears in shareable/confirmation URLs, and gifts carry
  // personal messages, so it must not be enumerable like a sequential number.
  id String @id @default(uuid())

  // Who is sending, and who receives the emailed bouquet.
  senderName     String
  senderEmail    String
  recipientName  String
  recipientEmail String

  // The letter shown on the card in the delivered email.
  message  String
  fromName String

  // Bouquet composition + the generated image we persist so it can be embedded
  // in the email that goes out later.
  stemCount Int
  imageData Bytes
  imageMime String @default("image/jpeg")

  // Scheduling. scheduledAt is stored in UTC; the sender picks a local time.
  scheduledAt DateTime
  status      GiftStatus @default(SCHEDULED)
  sentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flowers GiftFlower[]
  wraps   GiftWrap[]

  @@index([status, scheduledAt])
}

model GiftFlower {
  id String @id @default(cuid())

  giftId String
  gift   Gift   @relation(fields: [giftId], references: [id], onDelete: Cascade)

  flowerId String
  flower   Flower @relation(fields: [flowerId], references: [id])

  stemCount Int

  @@unique([giftId, flowerId])
}

model GiftWrap {
  id String @id @default(cuid())

  giftId String
  gift   Gift   @relation(fields: [giftId], references: [id], onDelete: Cascade)

  wrapColorId String
  wrapColor   WrapColor @relation(fields: [wrapColorId], references: [id])

  // 0 = primary wrap layer, 1 = secondary wrap layer when two colors are mixed
  position Int

  @@unique([giftId, wrapColorId])
}
