# Postgres connection string (Neon via Vercel Marketplace, or any Postgres).
# The integration writes DATABASE_URL into Vercel automatically; copy the same
# value here for local development. For `prisma migrate`, use the UNPOOLED URL.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Absolute public URL of the app. Used to build the QStash callback URL and the
# image URL embedded in emails. On Vercel this can be left unset (VERCEL_URL is
# used as a fallback), but set it to your real domain for stable links.
APP_URL="https://your-app.vercel.app"

# Cloudflare Workers AI — powers the AI bouquet image (app/api/generate-bouquet).
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Resend — sends the bouquet email to the recipient (lib/email.ts). Sign up free
# at resend.com and create an API key; it sends from onboarding@resend.dev with
# no domain verification needed.
RESEND_API_KEY=""

# Upstash QStash — schedules the delivery of each gift at its chosen time.
# Create a free QStash project at console.upstash.com; copy all three values.
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Optional. Lets you trigger /api/gifts/deliver manually (bypassing the QStash
# signature) with `Authorization: Bearer <this>` — handy for testing/admin.
INTERNAL_DELIVER_SECRET=""
