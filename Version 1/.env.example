# Postgres connection string used both by the Prisma CLI (migrate/seed/studio)
# and by the app at runtime. Works with either a Neon project or Vercel Postgres
# (Vercel Postgres is itself backed by Neon, so the connection string shape is
# the same) — use whichever has an existing Vercel Marketplace integration for you.
#
# Neon via Vercel Marketplace: Vercel project -> Storage -> Create Database -> Neon.
# The integration writes DATABASE_URL into your Vercel env vars automatically;
# copy that same value here for local development.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Cloudflare Workers AI, used by app/api/generate-bouquet/route.ts (already existed
# before this change, listed here for completeness).
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Optional. Guards POST /api/orders/[orderNumber]/payment (the stub that flips an
# order from PENDING_PAYMENT to CONFIRMED). When set, callers must send
# `Authorization: Bearer <this value>`. Leave unset only for local development.
# Set this in Vercel before wiring up a real Whish webhook or admin confirm action.
PAYMENT_WEBHOOK_SECRET=""

# Email notification sent to the florist whenever a new order is placed
# (lib/email.ts, called from POST /api/orders). Sign up free at resend.com,
# create an API key — no domain verification needed, it sends from Resend's
# shared onboarding@resend.dev sender out of the box.
RESEND_API_KEY=""
# Where new-order notifications should land — your own inbox.
FLORIST_NOTIFICATION_EMAIL="hallaldaniel@gmail.com"
